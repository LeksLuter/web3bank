```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.class
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
*.jar
*.war
*.zip
*.tar.gz

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs and coverage
*.log
*.tmp
coverage/
htmlcov/
.coverage

# System files
.DS_Store
Thumbs.db
```